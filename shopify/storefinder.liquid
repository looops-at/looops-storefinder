{%- comment -%}
  Looops Storefinder — Shopify Section
  ----------------------------------------------------------------
  Installation:
  1. In Shopify Admin → Online Store → Themes → Edit code
  2. Sections → "Add a new section" → Name: "storefinder" → Liquid
  3. Inhalt dieser Datei einfügen, speichern.
  4. Im Theme Editor auf der Ziel-Seite "Section hinzufügen" → "Storefinder"
  5. In den Section-Settings: Mapbox-Token + (falls nötig) Daten-URL eintragen.
{%- endcomment -%}

<section
  class="looops-storefinder-section"
  data-section-id="{{ section.id }}"
  style="
    --lsf-section-pad-y: {{ section.settings.padding_y | default: 48 }}px;
  ">
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <header class="lsf-section-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="lsf-section-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="lsf-section-sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>
  {%- endif -%}

  <div
    data-looops-storefinder
    data-data-url="{{ section.settings.data_url }}"
    data-mapbox-token="{{ section.settings.mapbox_token }}"
    data-default-center="{{ section.settings.default_lng | default: 13.5 }},{{ section.settings.default_lat | default: 47.6 }}"
    data-default-zoom="{{ section.settings.default_zoom | default: 5.8 }}"
    {%- if section.settings.map_style != blank %}
    data-map-style="{{ section.settings.map_style }}"
    {%- endif -%}
  ></div>
</section>

{%- liquid
  assign v = section.settings.bundle_version | default: 'main'
  assign repo = section.settings.github_repo | default: 'looops-at/looops-storefinder'
-%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/{{ repo }}@{{ v }}/dist/storefinder.css">
<script src="https://cdn.jsdelivr.net/gh/{{ repo }}@{{ v }}/dist/storefinder.js" defer></script>

<style>
  .looops-storefinder-section {
    padding: var(--lsf-section-pad-y, 48px) 0;
    max-width: 1280px;
    margin: 0 auto;
  }
  .lsf-section-header {
    padding: 0 16px 24px;
    text-align: center;
  }
  .lsf-section-title {
    margin: 0 0 8px;
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #1a1815;
  }
  .lsf-section-sub {
    margin: 0;
    color: #6e6760;
    font-size: 15px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
</style>

{% schema %}
{
  "name": "Storefinder",
  "tag": "section",
  "class": "section-storefinder",
  "settings": [
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Looops in deiner Nähe"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterzeile",
      "default": "Orte, an denen du unsere Düfte entdecken kannst. Filter nach Produkten, Partner-Typ oder Branche."
    },

    {
      "type": "header",
      "content": "Daten"
    },
    {
      "type": "url",
      "id": "data_url_link",
      "label": "stores.json URL (falls als Link)",
      "info": "Optional — Shopify Link-Picker. Wenn leer, wird das Textfeld unten verwendet."
    },
    {
      "type": "text",
      "id": "data_url",
      "label": "stores.json URL",
      "default": "https://cdn.jsdelivr.net/gh/looops-at/looops-storefinder@main/stores.json",
      "info": "Wird täglich automatisch via GitHub Action aktualisiert."
    },
    {
      "type": "text",
      "id": "github_repo",
      "label": "GitHub Repo (user/repo)",
      "default": "looops-at/looops-storefinder",
      "info": "Quelle für den JS/CSS-Bundle via jsDelivr."
    },
    {
      "type": "text",
      "id": "bundle_version",
      "label": "Bundle-Version / Tag",
      "default": "main",
      "info": "Git-Branch oder Tag. Verwende einen Tag (z.B. v1.0.0) für stabile Auslieferung."
    },

    {
      "type": "header",
      "content": "Mapbox"
    },
    {
      "type": "text",
      "id": "mapbox_token",
      "label": "Mapbox Public Token",
      "info": "pk.* Token aus mapbox.com. Empfehlung: URL-Restriction auf deinen Shop-Domain setzen."
    },
    {
      "type": "text",
      "id": "map_style",
      "label": "Mapbox Style-URL",
      "default": "mapbox://styles/mapbox/light-v11",
      "info": "Default = mapbox/light-v11 (minimalistisch). Eigene Styles möglich."
    },
    {
      "type": "number",
      "id": "default_lat",
      "label": "Default Karten-Mittelpunkt — Latitude",
      "default": 47.6
    },
    {
      "type": "number",
      "id": "default_lng",
      "label": "Default Karten-Mittelpunkt — Longitude",
      "default": 13.5
    },
    {
      "type": "range",
      "id": "default_zoom",
      "label": "Default Zoom",
      "min": 3,
      "max": 14,
      "step": 0.5,
      "default": 5.5
    },

    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertikales Padding",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 48,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Storefinder",
      "category": "Custom"
    }
  ]
}
{% endschema %}
