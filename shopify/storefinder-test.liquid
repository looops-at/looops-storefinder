(function(){
  var sectionId = {{ section.id | json }};
  var container = document.getElementById('lsf-test-' + sectionId);
  if (!container) return;
  var dataEl = document.getElementById('lsf-test-data-' + sectionId);
  var data = dataEl ? JSON.parse(dataEl.textContent) : { stores: [] };
  var token = container.dataset.mapboxToken;
  var center = (container.dataset.defaultCenter || '13.5,47.6').split(',').map(Number);
  var zoom = Number(container.dataset.defaultZoom || 5.5);
  LooopsStorefinder.init(container, { data: data, mapboxToken: token, defaultCenter: center, defaultZoom: zoom });
})();
