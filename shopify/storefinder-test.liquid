sform:scale(1.35)}.lsf-marker.is-premium{border-color:var(--lsf-premium)}.lsf-marker.is-premium.is-active{background:var(--lsf-premium);border-color:var(--lsf-premium)}.lsf-root .mapboxgl-ctrl-group{border-radius:2px;box-shadow:0 1px 6px #0000000f}.lsf-root .mapboxgl-ctrl-attrib{font-size:10px}@media(max-width:768px){.lsf-filters{padding:var(--lsf-pad)}.lsf-split{grid-template-columns:1fr;grid-template-rows:50vh 50vh;min-height:0;height:auto}.lsf-list-wrap{border-right:none;border-top:1px solid var(--lsf-border);order:2}.lsf-map-wrap{order:1}.lsf-search{flex:1 1 100%;max-width:none}}
</style>

