{% schema %}
{
  "name": "Storefinder Test",
  "tag": "section",
  "class": "section-storefinder-test",
  "settings": [
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Looops in deiner Nähe"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterzeile",
      "default": "TEST-VERSION mit 6 Beispiel-Stores. Filter funktionieren, Daten sind Dummy."
    },
    {
      "type": "header",
      "content": "Mapbox"
    },
    {
      "type": "text",
      "id": "mapbox_token",
      "label": "Mapbox Public Token",
      "info": "pk.* Token aus mapbox.com — wird im Client-Code eingebettet, gehört dort hin."
    },
    {
      "type": "number",
      "id": "default_lat",
      "label": "Karten-Mittelpunkt — Latitude",
      "default": 47.6
    },
    {
      "type": "number",
      "id": "default_lng",
      "label": "Karten-Mittelpunkt — Longitude",
      "default": 13.5
    },
    {
      "type": "range",
      "id": "default_zoom",
      "label": "Default Zoom",
      "min": 3,
      "max": 14,
      "step": 0.5,
      "default": 5.5
    }
  ],
  "presets": [
    {
      "name": "Storefinder Test",
      "category": "Custom"
    }
  ]
}
{% endschema %}
