{%- comment -%}
  Looops Storefinder — TEST-Version (all-inline)
  ----------------------------------------------------------------
  Diese Datei ist self-contained: JS + CSS + Sample-Daten sind alle
  inline. KEIN GitHub / CDN nötig. Perfekt zum Testen in Shopify
  bevor wir das richtige Setup deployen.

  Installation:
  1. Online Store → Themes → Edit code
  2. Sections → "Add a new section" → Name: "storefinder-test" → Liquid
  3. Diese Datei reinkopieren, speichern.
  4. Im Theme Editor auf der Ziel-Page → "Section hinzufügen" → "Storefinder Test"
  5. In den Settings: Mapbox Token eintragen (Default ist vorausgefüllt).

  Wenn alles ok aussieht: auf die normale storefinder.liquid umsteigen
  (lädt JS/CSS via jsDelivr vom GitHub-Repo und die echten Daten).
{%- endcomment -%}

<section class="lsf-test-section" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <header class="lsf-test-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="lsf-test-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="lsf-test-sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>
  {%- endif -%}

  <div
    id="lsf-test-{{ section.id }}"
    data-mapbox-token="{{ section.settings.mapbox_token }}"
    data-default-center="{{ section.settings.default_lng | default: 13.5 }},{{ section.settings.default_lat | default: 47.6 }}"
    data-default-zoom="{{ section.settings.default_zoom | default: 5.5 }}"
  ></div>
</section>

<style>
  .lsf-test-section {
    padding: 48px 0;
    max-width: 1280px;
    margin: 0 auto;
  }
  .lsf-test-header {
    padding: 0 16px 24px;
    text-align: center;
  }
  .lsf-test-title {
    margin: 0 0 8px;
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #1a1815;
  }
  .lsf-test-sub {
    margin: 0 auto;
    color: #6e6760;
    font-size: 15px;
    max-width: 560px;
  }

  /* ─── Storefinder Bundle CSS (minified) ─── */
